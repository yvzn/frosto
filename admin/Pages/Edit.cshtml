@page "{id}"
@model admin.Pages.EditModel
@{
	ViewData["Title"] = $"Edit {Model.ValidLocation.city} Location";
}

@section Head
{
	<link rel="stylesheet" href="https://atlas.microsoft.com/sdk/javascript/mapcontrol/2/atlas.min.css" type="text/css" />
	<script src="https://atlas.microsoft.com/sdk/javascript/mapcontrol/2/atlas.min.js"></script>
}

<div class="row">
	<form method="post" class="col-lg-6 p-5 mb-5 border rounded-3 bg-light">
		<h2 class="text-muted mb-3">Edit location</h2>

		<div class="form-group mb-3">
			<label asp-for="ValidLocation.city" class="form-label"></label>
			<input asp-for="ValidLocation.city" class="form-control" id="valid-location-city" required />
			<span asp-validation-for="ValidLocation.city" class="text-danger"></span>
		</div>
		<div class="row gx-3">
			<div class="form-group col-md-6 mb-3">
				<label asp-for="ValidLocation.zipCode" class="form-label"></label>
				<input asp-for="ValidLocation.zipCode" class="form-control" />
				<span asp-validation-for="ValidLocation.zipCode" class="text-danger"></span>
			</div>
			<div class="form-group col-md-6 mb-3">
				<label asp-for="ValidLocation.country" class="form-label"></label>
				<input asp-for="ValidLocation.country" class="form-control" list="country-names"
					id="valid-location-country" required />
				<span asp-validation-for="ValidLocation.country" class="text-danger"></span>

				<datalist id="country-names">
					@foreach (var country in Model.CountryList)
					{
						<option value="@country"></option>
					}
				</datalist>
			</div>
		</div>
		<div class="form-group mb-3">
			<label asp-for="ValidLocation.coordinates" class="form-label"></label>
			<input asp-for="ValidLocation.coordinates" class="form-control" id="valid-location-coordinates" required />
			<span asp-validation-for="ValidLocation.coordinates" class="text-danger"></span>
		</div>
		<div class="form-group mb-3" id="users-editor">
			<label asp-for="ValidLocation.users" class="form-label"></label>
			<input asp-for="ValidLocation.users" type="hidden" id="users-hidden" />
			<span asp-validation-for="ValidLocation.users" class="text-danger d-block mb-1"></span>
			<ul id="users-list" class="list-unstyled d-flex flex-wrap gap-2 mb-2" aria-label="User email list" role="list"></ul>
			<div class="input-group">
				<input type="email" id="users-new-email" class="form-control" placeholder="Add email address"
					aria-label="New email address" autocomplete="off" />
				<button type="button" id="users-add-btn" class="btn btn-outline-secondary">Add</button>
			</div>
			<div id="users-new-email-error" class="text-danger mt-1" role="alert" aria-live="polite"></div>
		</div>
		<div class="row gx-3">
			<div class="form-group col-md-6 mb-3 form-check form-switch">
				<input asp-for="ValidLocation.uat" class="form-check-input" type="checkbox" role="switch" />
				<label asp-for="ValidLocation.uat" class="form-check-label"></label>
				<span asp-validation-for="ValidLocation.uat" class="text-danger"></span>
			</div>
			<div class="form-group col-md-6 mb-3 form-check form-switch">
				<input asp-for="ValidLocation.disabled" class="form-check-input" type="checkbox" role="switch" />
				<label asp-for="ValidLocation.disabled" class="form-check-label"></label>
				<span asp-validation-for="ValidLocation.disabled" class="text-danger"></span>
			</div>
		</div>
		<div class="row gx-3">
			<div class="form-group col-md-6 mb-3">
				<label asp-for="ValidLocation.channel" class="form-label"></label>
				<select asp-for="ValidLocation.channel" asp-items="Model.ChannelOptions" class="form-select"></select>
			</div>
			<div class="form-group col-md-6 mb-3">
				<label asp-for="ValidLocation.lang" class="form-label"></label>
				<input asp-for="ValidLocation.lang" class="form-control" />
				<span asp-validation-for="ValidLocation.lang" class="text-danger"></span>
			</div>
		</div>
		<div class="row gx-3">
			<div class="form-group col-md-6 mb-3">
				<label asp-for="ValidLocation.timezone" class="form-label"></label>
				<input asp-for="ValidLocation.timezone" class="form-control" list="timezone-names" />
				<span asp-validation-for="ValidLocation.timezone" class="text-danger"></span>

				<datalist id="timezone-names">
					@foreach (var timezone in Model.TimezoneList)
					{
						<option value="@timezone"></option>
					}
				</datalist>
			</div>
			<div class="form-group col-md-6 mb-3">
				<label asp-for="ValidLocation.offset" class="form-label"></label>
				<input asp-for="ValidLocation.offset" class="form-control" placeholder="+02:00" />
				<span asp-validation-for="ValidLocation.offset" class="text-danger"></span>
			</div>
		</div>

		<input asp-for="ValidLocation.Id" />
		<span asp-validation-for="ValidLocation.Id" class="text-danger"></span>

		<div class="btn-toolbar justify-content-between">
			<button type="submit" class="btn btn-primary">Update</button>
			<button type="reset" class="btn btn-outline-secondary ">Reset</button>
		</div>
	</form>

	<section class="col-lg-6 p-5 mb-5">
		<h2 class="text-muted mb-3">Current coordinates</h2>
		<div id="coordinates-map" class="w-100 border rounded-3 shadow-sm" style="height: 320px;"></div>
	</section>

	<div hidden>
		@Html.ValidationSummary()
	</div>
</div>

<script>
	var azureMapsSubscriptionKey = '@Model.AzureMapsSubscriptionKey';
	var coordinatesMap;
	var coordinatesMarker;

	function initCoordinatesMap(latitude, longitude) {
		if (typeof atlas === 'undefined') {
			console.warn('Azure Maps SDK not available.');
			return;
		}

		if (!azureMapsSubscriptionKey) {
			console.warn('Azure Maps subscription key not configured; skipping map preview.');
			return;
		}

		coordinatesMap = new atlas.Map('coordinates-map', {
			center: [longitude, latitude],
			zoom: 12,
			language: 'en-US',
			view: 'Auto',
			authOptions: {
				authType: 'subscriptionKey',
				subscriptionKey: azureMapsSubscriptionKey
			}
		});

		coordinatesMap.events.add('ready', function () {
			coordinatesMarker = new atlas.HtmlMarker({
				color: '#2563eb',
				position: [longitude, latitude]
			});
			coordinatesMap.markers.add(coordinatesMarker);
		});
	}

	(function () {
		var rawCoordinates = '@Model.ValidLocation.coordinates';
		if (!rawCoordinates) return;
		var parts = rawCoordinates.split(',').map(function (p) { return p.trim(); });
		if (parts.length < 2) return;
		var latitude = Number(parts[0]);
		var longitude = Number(parts[1]);
		if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) return;
		initCoordinatesMap(latitude, longitude);
	})();

	(function () {
		var hiddenInput = document.getElementById('users-hidden');
		var usersList = document.getElementById('users-list');
		var newEmailInput = document.getElementById('users-new-email');
		var addBtn = document.getElementById('users-add-btn');
		var errorDiv = document.getElementById('users-new-email-error');

		function getEmails() {
			var val = hiddenInput.value.trim();
			if (!val) return [];
			return val.split(',').map(function (e) { return e.trim(); }).filter(function (e) { return e.length > 0; });
		}

		function syncHidden(emails) {
			hiddenInput.value = emails.join(',');
		}

		function isValidEmail(email) {
			return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
		}

		function renderChips() {
			var emails = getEmails();
			usersList.innerHTML = '';
			emails.forEach(function (email) {
				var li = document.createElement('li');
				li.className = 'badge text-bg-secondary d-inline-flex align-items-center gap-1 px-2 py-1 fs-6 fw-normal';
				li.setAttribute('role', 'listitem');

				var span = document.createElement('span');
				span.textContent = email;

				var btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'btn-close btn-close-white ms-1';
				btn.style.fontSize = '0.6em';
				btn.setAttribute('aria-label', 'Remove ' + email);
				btn.addEventListener('click', function () {
					var current = getEmails();
					var updated = current.filter(function (e) { return e !== email; });
					syncHidden(updated);
					renderChips();
				});

				li.appendChild(span);
				li.appendChild(btn);
				usersList.appendChild(li);
			});
		}

		function addEmail() {
			var email = newEmailInput.value.trim();
			errorDiv.textContent = '';
			if (!email) {
				errorDiv.textContent = 'Please enter an email address.';
				newEmailInput.focus();
				return;
			}
			if (!isValidEmail(email)) {
				errorDiv.textContent = 'Please enter a valid email address.';
				newEmailInput.focus();
				return;
			}
			var current = getEmails();
			if (current.some(function (e) { return e.toLowerCase() === email.toLowerCase(); })) {
				errorDiv.textContent = 'This email address is already in the list.';
				newEmailInput.focus();
				return;
			}
			current.push(email);
			syncHidden(current);
			renderChips();
			newEmailInput.value = '';
			newEmailInput.focus();
		}

		addBtn.addEventListener('click', addEmail);

		newEmailInput.addEventListener('keydown', function (e) {
			if (e.key === 'Enter') {
				e.preventDefault();
				addEmail();
			}
		});

		var form = hiddenInput.closest('form');
		if (form) {
			form.addEventListener('reset', function () {
				setTimeout(renderChips, 0);
			});
		}

		renderChips();
	})();
</script>
